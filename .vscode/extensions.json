{
    "recommendations": [
        // * Git extensions

        // Git History: shows the commit history (+ git log) per commit. Similar to GitLens
        // file history but at commit granularity. Both work well together.
        "donjayamanne.githistory",
        // Git Graph: visualises the commit graph. Very useful on projects with many branches,
        // merges, and checkouts.
        "mhutchie.git-graph",
        // Git Blame: shows author and commit message on mouse-over for any line.
        "waderyan.gitblame",

        // * Commit convention extensions

        // Gitmoji for VS Code: inserts gitmoji into commit messages to make them easier to
        // read at a glance.
        "seatonjiang.gitmoji-vscode",
        // Commit Message Editor: a GUI editor for writing commit messages; useful for
        // defining and reusing commit templates.
        "adam-bender.commit-message-editor",

        // * Code comment extensions

        // Better Comments: highlights TODO, FIXME, NOTE and other annotation keywords in
        // distinct colors/styles.
        "aaron-bond.better-comments",
        // Doxygen Document Generator: auto-generates Doxygen comment blocks from
        // function/class signatures.
        "cschlosser.doxdocgen",

        // * Error-prevention extensions (linters, formatters, typo checkers, etc.)

        // Markdown All in One: comprehensive Markdown support — HTML export, code/math block
        // toggle, and more.
        "yzhang.markdown-all-in-one",
        // markdownlint: checks Markdown syntax including heading levels and broken links.
        "davidanson.vscode-markdownlint",

        // * Productivity extensions

        // CMake Formatter: formats CMake script files (CMakeLists.txt, *.cmake).
        "intellect-ind-in.cmake-formatter",
        // Better Folding: enhanced code folding with finer-grained collapse/expand control.
        "mohammadbaqer.better-folding",
        // PowerShell: official extension for running and debugging PowerShell scripts inside
        // VS Code.
        "ms-vscode.powershell",
        // Doxygen: syntax highlighting and convenience features for Doxygen-style comments
        // in C/C++.
        "bbenoist.doxygen",
        // Doxygen Runner: runs Doxygen to generate HTML/PDF documentation from the current
        // project.
        "betwo.vscode-doxygen-runner",
        // vscode-pdf: opens and previews PDF files directly inside VS Code.
        "tomoki1207.pdf",

        // * C/C++ development extensions

        // C/C++: IntelliSense, debugging, and code navigation. The single core extension is
        // recommended over the meta-package.
        "ms-vscode.cpptools",

        // * CMake development extensions

        // CMake Tools: official extension for configuring, building, and debugging
        // CMake-based C/C++ projects.
        "ms-vscode.cmake-tools",
        // CMake: syntax highlighting for CMake scripts (CMakeLists.txt, *.cmake).
        "twxs.cmake",

        // * Cortex-M debug extensions

        // Cortex-Debug: debugger extension for Arm Cortex-M MCUs; integrates with hardware
        // debug probes (J-Link, OpenOCD, etc.).
        "marus25.cortex-debug",
        // Debug Tracker: companion extension that tracks and records debug session history
        // and state during Cortex-M debugging.
        "mcu-debug.debug-tracker-vscode",
        // Memory View: visualises memory regions (heap, stack, registers, etc.) during a
        // debug session.
        "mcu-debug.memory-view",
        // Peripheral Viewer: GUI view of registers and peripherals during a Cortex-M debug
        // session.
        "mcu-debug.peripheral-viewer",

        // * Cortex-M development extensions

        // ARM: syntax highlighting for Arm assembly language.
        "dan-c-underwood.arm",
        // Linker Script: syntax highlighting for linker scripts (.ld, etc.) to ease editing
        // of build configurations.
        "zixuanwang.linkerscript",
        // GNU Map Files: syntax highlighting and symbol list view for .map files generated
        // by the GNU linker; useful for analysing flash/RAM usage.
        "trond-snekvik.gnu-mapfiles",
        // Hex Editor: opens and edits binary files in hexadecimal view.
        "ms-vscode.hexeditor",
        // Better C++ Syntax: improved C++ syntax highlighting, especially for template and
        // metaprogramming code.
        "jeff-hykin.better-cpp-syntax"
    ]
}
