{
    // ---- CMake Tools extension ----------------------------------------
    // Force preset-driven configuration + Ninja so the CMake Tools UI
    // calls into the same flow that `tasks.json` uses. Without this
    // some third-party extensions (e.g. STM32-focused ones) replace the
    // active cmake with a wrapper that ignores our presets.
    "cmake.useCMakePresets": "always",
    "cmake.generator": "Ninja",
    "cmake.preferredGenerators": ["Ninja"],
    "cmake.configureOnOpen": false,
    "cmake.automaticReconfigure": false,

    // Default cmake/ninja name; PATH-resolved at task time. If your PATH
    // resolves these to a vendor wrapper (e.g. STM32CubeCLT's bundled
    // cmake or any "cube-cmake.exe"-style shim), override them in
    // ".vscode/settings.local.json" (already gitignored) with absolute
    // paths, for example:
    //   "cmake.cmakePath": "C:/Program Files/CMake/bin/cmake.exe",
    //   "cmake.ninjaPath": "C:/Program Files/Ninja/ninja.exe"
    "cmake.cmakePath": "C:/Program Files/CMake/bin/cmake.exe",
    "cmake.ninjaPath": "ninja",

    // Always inject ARM_TOOLCHAIN_DIR at configure time so the toolchain
    // file resolves "arm-none-eabi-gcc" to the official Arm GNU toolchain
    // even when CMakeUserPresets.json is not loaded or the developer
    // picks the shared "debug"/"release" preset directly. Bypasses
    // STM32CubeCLT's bundled GNU tools that would otherwise win PATH
    // lookup on a typical Windows install.
    "cmake.configureSettings": {
        "ARM_TOOLCHAIN_DIR": "C:/Program Files (x86)/Arm/GNU Toolchain mingw-w64-i686-arm-none-eabi/bin"
    },

    // ---- File hygiene -------------------------------------------------
    "files.eol": "\n",
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,

    // ---- C / C++ basics ----------------------------------------------
    "[c]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "[cpp]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    }
}
