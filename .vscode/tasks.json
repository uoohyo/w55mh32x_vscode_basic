{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Clean (debug)",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "--preset", "debug", "--target", "clean"],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": []
        },
        {
            "label": "CMake: configure (debug)",
            "type": "shell",
            "command": "cmake",
            "args": ["--preset", "debug"],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": []
        },
        {
            "label": "Build (debug)",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "--preset", "debug"],
            "options": { "cwd": "${workspaceFolder}" },
            "group": { "kind": "build", "isDefault": true },
            "dependsOn": ["CMake: configure (debug)"],
            "dependsOrder": "sequence",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Clean and Build (debug)",
            "dependsOn": ["Clean (debug)", "Build (debug)"],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "Clean (release)",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "--preset", "release", "--target", "clean"],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": []
        },
        {
            "label": "CMake: configure (release)",
            "type": "shell",
            "command": "cmake",
            "args": ["--preset", "release"],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": []
        },
        {
            "label": "Build (release)",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "--preset", "release"],
            "options": { "cwd": "${workspaceFolder}" },
            "group": { "kind": "build", "isDefault": true },
            "dependsOn": ["CMake: configure (release)"],
            "dependsOrder": "sequence",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Clean and Build (release)",
            "dependsOn": ["Clean (release)", "Build (release)"],
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}
