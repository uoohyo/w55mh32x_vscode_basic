{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                // ARM_TOOLCHAIN_DIR: ARM GCC 툴체인 bin 디렉토리 절대 경로.
                // Windows 예시: "C:/Program Files (x86)/Arm/GNU Toolchain mingw-w64-i686-arm-none-eabi/bin"
                // Linux 예시:   "/usr/bin" 또는 "/opt/arm-gnu-toolchain/bin"
                // arm-none-eabi-gcc 실행 파일이 들어 있는 디렉토리를 지정하세요.
                // 툴체인이 이미 PATH에 있으면 이 주석과 아래 ARM_TOOLCHAIN_DIR 줄을 함께 지우세요.
                // 복사 후 실제 경로로 수정하고, 이 // 주석 줄들은 모두 제거하세요.
                "ARM_TOOLCHAIN_DIR": "C:/Program Files (x86)/Arm/GNU Toolchain mingw-w64-i686-arm-none-eabi/bin",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "TRUE"
            }
        },
        {
            "name": "debug",
            "inherits": "base",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "release",
            "inherits": "base",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        }
    ],
    "buildPresets": [
        { "name": "debug",   "configurePreset": "debug" },
        { "name": "release", "configurePreset": "release" }
    ]
}
