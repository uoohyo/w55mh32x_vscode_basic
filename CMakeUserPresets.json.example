{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
    "configurePresets": [
        {
            "name": "toolchain-windows",
            "hidden": true,
            "cacheVariables": {
                "ARM_TOOLCHAIN_DIR": "C:/Program Files (x86)/Arm/GNU Toolchain mingw-w64-i686-arm-none-eabi/bin"
            }
        },
        {
            "name": "toolchain-linux",
            "hidden": true,
            "cacheVariables": {
                "ARM_TOOLCHAIN_DIR": "/usr/bin"
            }
        },
        {
            "name": "dev-debug",
            "displayName": "Dev Debug (local toolchain)",
            "inherits": ["debug", "toolchain-windows"]
        },
        {
            "name": "dev-release",
            "displayName": "Dev Release (local toolchain)",
            "inherits": ["release", "toolchain-windows"]
        }
    ],
    "buildPresets": [
        { "name": "dev-debug",   "configurePreset": "dev-debug" },
        { "name": "dev-release", "configurePreset": "dev-release" }
    ]
}
